# Supabase — used server-side only.
# NEXT_PUBLIC_SUPABASE_URL is safe to expose; the service role key is NOT.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Resend — sends the completion notification email.
RESEND_API_KEY=

# Where the "setup complete" notification is sent.
NOTIFY_EMAIL=admin@whitneybateson.com

# The verified sender address the notification comes from.
FROM_EMAIL=notifications@whitneybateson.com
