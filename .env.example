# Supabase — used server-side only.
# NEXT_PUBLIC_SUPABASE_URL is safe to expose; the service role key is NOT.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Gmail notifications (help requests + completion summaries).
# GMAIL_USER is the sending Gmail/Workspace address.
# GMAIL_APP_PASSWORD is a Google App Password (needs 2-Step Verification on
# that account) — NOT the normal account password.
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Where notifications are sent.
NOTIFY_EMAIL=admin@whitneybateson.com
